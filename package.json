{
  "name": "@bigfootds/bigfootds-shared-data",
  "version": "1.0.18",
  "description": "Shared data used by more than one service in the BigfootDS system.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./data/errors/DataErrors": {
      "types": "./dist/data/errors/DataErrors.d.ts",
      "require": "./dist/data/errors/DataErrors.js",
      "default": "./dist/data/errors/DataErrors.js"
    },
    "./data/httpStatusCodes": {
      "types": "./dist/data/httpStatusCodes.d.ts",
      "require": "./dist/data/httpStatusCodes.js",
      "default": "./dist/data/httpStatusCodes.js"
    },
    "./data/profanityList": {
      "types": "./dist/data/profanityList.d.ts",
      "require": "./dist/data/profanityList.js",
      "default": "./dist/data/profanityList.js"
    },
    "./src": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./src/index": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./src/index.js": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./src/data/errors/DataErrors": {
      "types": "./dist/data/errors/DataErrors.d.ts",
      "require": "./dist/data/errors/DataErrors.js",
      "default": "./dist/data/errors/DataErrors.js"
    },
    "./src/data/errors/DataErrors.js": {
      "types": "./dist/data/errors/DataErrors.d.ts",
      "require": "./dist/data/errors/DataErrors.js",
      "default": "./dist/data/errors/DataErrors.js"
    },
    "./src/data/httpStatusCodes": {
      "types": "./dist/data/httpStatusCodes.d.ts",
      "require": "./dist/data/httpStatusCodes.js",
      "default": "./dist/data/httpStatusCodes.js"
    },
    "./src/data/httpStatusCodes.js": {
      "types": "./dist/data/httpStatusCodes.d.ts",
      "require": "./dist/data/httpStatusCodes.js",
      "default": "./dist/data/httpStatusCodes.js"
    },
    "./src/data/profanityList": {
      "types": "./dist/data/profanityList.d.ts",
      "require": "./dist/data/profanityList.js",
      "default": "./dist/data/profanityList.js"
    },
    "./src/data/profanityList.js": {
      "types": "./dist/data/profanityList.d.ts",
      "require": "./dist/data/profanityList.js",
      "default": "./dist/data/profanityList.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "npm run build && node --test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BigfootDS/pkg-shared-data.git"
  },
  "keywords": [],
  "author": "Alex Stormwood <alex.stormwood@bigfootds.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/BigfootDS/pkg-shared-data/issues"
  },
  "homepage": "https://github.com/BigfootDS/pkg-shared-data#readme",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  }
}
